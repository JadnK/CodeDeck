+  border-color: color-mix(in srgb, var(--accent) 48%, var(--border));
+}
+
+.git-bulk-stage-option > span:first-child {
+  display: grid;
+  min-width: 0;
+  gap: 3px;
+}
+
+.git-bulk-stage-option strong {
+  overflow: hidden;
+  font-size: 11px;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.git-bulk-stage-option small,
+.git-bulk-stage-note {
+  color: var(--text-faint);
+  font-size: 9.5px;
+  line-height: 1.4;
+}
+
+.git-bulk-stage-option:disabled {
+  cursor: not-allowed;
+  opacity: 0.48;
+}
+
+.git-bulk-stage-note {
+  margin: 0;
+}
+
+@media (max-width: 1100px) {
+  .git-bulk-stage-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (max-width: 620px) {
+  .git-bulk-stage-grid {
+    grid-template-columns: 1fr;
+  }
+}
