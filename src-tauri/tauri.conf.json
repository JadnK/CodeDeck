{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Code Deck",
  "version": "1.1.0",
  "identifier": "dev.codedeck.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Code Deck",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Organize, launch and manage local coding projects.",
    "longDescription": "Code Deck is a local desktop dashboard for developers to organize projects, launch IDEs, run commands, inspect Git status and start workspaces.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0MkE4MUE1RjZCMTkxMEMKUldRTWtiSDJwWUVxRkU1VkV5STBPaDdkNWRmQ2pEMjVCM1RTSWVxZGV6aHlZU3BBWVhNR2QwK04K",
      "endpoints": [
        "https://github.com/JadnK/CodeDeck/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
