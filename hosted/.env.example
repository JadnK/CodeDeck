# Absolute path on the Linux host containing your projects.
CODEDECK_PROJECTS_PATH=/srv/projects

# Generate with: openssl rand -hex 32
CODEDECK_WEB_TOKEN=replace-with-a-long-random-token

# Safe default: accessible only on the server itself. Use a reverse proxy, VPN or SSH tunnel.
CODEDECK_BIND_ADDRESS=127.0.0.1
CODEDECK_PORT=8080

# Published release image. Use edge for every push to main.
CODEDECK_IMAGE=ghcr.io/jadnk/codedeck-web:latest
